{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure vs2022-x64",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset=vs2022-x64"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cmake: debug rendering",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset=vs2022-x64-debug", "--target", "winelement_rendering"],
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "cmake: debug platform",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset=vs2022-x64-debug", "--target", "winelement_platform"],
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "cmake: build rendering",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset=vs2022-x64-release", "--target", "winelement_rendering"],
      "group": "build",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "cmake: build platform",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset=vs2022-x64-release", "--target", "winelement_platform"],
      "group": "build",
      "problemMatcher": ["$msCompile"]
    }
  ]
}
